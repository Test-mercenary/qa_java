.idea/

# Maven build output; отчёт JaCoCo (target/site/jacoco) можно коммитить по заданию
.idea/
*.iml

# игнорируем всё в target
target/*

# но разрешаем папку site
!target/site/

# внутри site снова игнорируем всё
target/site/*

# но разрешаем jacoco
!target/site/jacoco/
!target/site/jacoco/**

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
